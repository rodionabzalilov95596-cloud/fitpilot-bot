PORT=3000

# Одноразово для загрузки на GitHub (push-github.bat): https://github.com/settings/tokens → repo
GITHUB_TOKEN=

# Публичный HTTPS-адрес (для miniapp календаря в MAX).
# На Render задаётся автоматически как RENDER_EXTERNAL_URL — PUBLIC_URL можно не указывать.
# Локально miniapp из MAX не откроется без HTTPS-туннеля; для теста используйте Render.
PUBLIC_URL=https://fitpilot-bot.onrender.com

# Storage
DATA_DIR=./data

# VK bot (long polling для тестов с десктопа)
# Можно положить только токен vk1.... в .env.txt — он подхватится автоматически
VK_BOT_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199

# MAX bot (long polling)
MAX_BOT_TOKEN=
# Тот же URL, что PUBLIC_URL + /miniapp/schedule/ — в MAX:
# business.max.ru → Чат-боты → Расширенные настройки → URL мини-приложения
# MAX_API_BASE_URL=https://platform-api.max.ru
# MAX_WEBHOOK_SECRET=

# LLM provider: openai | yandex | mock
LLM_PROVIDER=openai

# OpenAI (или любой совместимый API: OpenRouter, ProxyAPI и т.д.)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# YandexGPT (Yandex Cloud) — рекомендуется API-ключ сервисного аккаунта
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1g...
YANDEX_MODEL_URI=gpt://b1g.../yandexgpt-5.1/latest
# YANDEX_IAM_TOKEN=   # альтернатива API-ключу, живёт ~12 часов
YANDEX_API_BASE_URL=https://llm.api.cloud.yandex.net

